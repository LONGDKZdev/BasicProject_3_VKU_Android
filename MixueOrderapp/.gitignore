node_modules/

# ---- Keep Gradle Wrapper tracked ----
!gradle/wrapper/
!gradle/wrapper/gradle-wrapper.jar
!gradle/wrapper/gradle-wrapper.properties

# ---- Do NOT commit bundled Gradle distributions ----
/gradle-*/

# ---- Never commit keystores/secrets ----
*.jks
*.keystore
*.p12

# ---- APK/AAB outputs ----
*.apk
*.aab

