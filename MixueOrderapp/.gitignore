# ---- Android / Gradle ----
.gradle/
**/build/
out/

# Local-only SDK/IDE config
local.properties

# IntelliJ / Android Studio
.idea/
*.iml
*.ipr
*.iws

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# External native build
.externalNativeBuild/
.cxx/

# Kotlin / tooling
.kotlin/

